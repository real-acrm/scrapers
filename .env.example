# Copy to .env (local dev) / .env.staging / .env.production.
# Only .env.example is committed; the others are gitignored.

# Scraper credentials — one pair per wholesaler.
NALEO_LOGIN=
NALEO_PASSWORD=
KAJA_LOGIN=
KAJA_PASSWORD=
GOLDENSNEAKERS_LOGIN=
GOLDENSNEAKERS_PASSWORD=
BRANDSDISTRIBUTION_LOGIN=
BRANDSDISTRIBUTION_PASSWORD=
BRANDSGATEWAY_LOGIN=
BRANDSGATEWAY_GMAIL_USER=
BRANDSGATEWAY_GMAIL_APP_PASSWORD=
BRANDSGATEWAY_MEILI_HOST=
BRANDSGATEWAY_MEILI_TOKEN=
BRANDSGATEWAY_MODE=full
OVERSOLES_LOGIN=
OVERSOLES_PASSWORD=
# Base64 Shopify session cookies; refreshed weekly by `scripts/oversoles-refresh-cookies.ts`.
OVERSOLES_SESSION_B64=

# Database — Neon Postgres (pooled connection string)
#   local dev:   postgres://localhost/b2b_scrapers_dev (or rely on PGlite in tests)
#   staging:     postgres://user:pass@<branch>-pooler.neon.tech/b2b_scrapers?sslmode=require
#   production:  postgres://user:pass@<branch>-pooler.neon.tech/b2b_scrapers?sslmode=require
DATABASE_URL=
