# Copy to .env (local dev) / .env.staging / .env.production.
# Only .env.example is committed; the others are gitignored.

# Scraper credentials — one pair per wholesaler.
NALEO_LOGIN=
NALEO_PASSWORD=
KAJA_LOGIN=
KAJA_PASSWORD=
GOLDENSNEAKERS_LOGIN=
GOLDENSNEAKERS_PASSWORD=
BRANDSDISTRIBUTION_LOGIN=
BRANDSDISTRIBUTION_PASSWORD=
BRANDSGATEWAY_LOGIN=
BRANDSGATEWAY_GMAIL_USER=
BRANDSGATEWAY_GMAIL_APP_PASSWORD=
BRANDSGATEWAY_MEILI_HOST=
BRANDSGATEWAY_MEILI_TOKEN=
BRANDSGATEWAY_MODE=full

# Database — Neon Postgres (pooled connection string)
#   local dev:   postgres://localhost/naleo_dev (or rely on PGlite in tests)
#   staging:     postgres://user:pass@<branch>-pooler.neon.tech/naleodb?sslmode=require
#   production:  postgres://user:pass@<branch>-pooler.neon.tech/naleodb?sslmode=require
DATABASE_URL=
# Legacy (kept commented for one PR cycle, remove in cleanup):
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=

# CORS: allowed frontend origins for the storefront API.
# Comma-separated; "*" allows any origin.
#   dev:   http://localhost:3000
#   prod:  https://app.example.com,https://staging.example.com
CORS_ORIGIN=*
